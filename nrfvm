#!/usr/bin/env bash

NRFVM_VERSION="0.1.0"
NRFVM_DIR="${NRFVM_DIR:-$HOME/.nrfvm}"
NRFVM_CONFIG_FILE="$NRFVM_DIR/config"
NRFVM_STATE_DIR="$NRFVM_DIR/state"

_NRFVM_VERBOSE=0

_nrfvm_is_zsh() {
  [ -n "${ZSH_VERSION:-}" ]
}

_nrfvm_is_bash() {
  [ -n "${BASH_VERSION:-}" ]
}

_nrfvm_is_supported_shell() {
  _nrfvm_is_bash || _nrfvm_is_zsh
}

_nrfvm_is_sourced() {
  if _nrfvm_is_bash; then
    [ "${BASH_SOURCE[0]}" != "$0" ]
    return
  fi
  if _nrfvm_is_zsh; then
    case $ZSH_EVAL_CONTEXT in
      *:file) return 0 ;;
      *) return 1 ;;
    esac
  fi
  return 1
}

_nrfvm_err() {
  printf "nrfvm: %s\n" "$1" >&2
}

_nrfvm_info() {
  printf "%s\n" "$1"
}

_nrfvm_warn() {
  printf "nrfvm: %s\n" "$1" >&2
}

_nrfvm_default_sdk_install_dir() {
  case "$(uname -s 2>/dev/null || true)" in
    Darwin) printf "%s" "/opt/nordic/ncs" ;;
    *) printf "%s" "$HOME/ncs" ;;
  esac
}

_nrfvm_sdk_install_dir_is_configurable() {
  case "$(uname -s 2>/dev/null || true)" in
    Darwin) return 1 ;;
    *) return 0 ;;
  esac
}

_nrfvm_mkdirs() {
  local old_umask=""
  local mk_status=0
  old_umask="$(umask)"
  umask 077
  mkdir -p "$NRFVM_DIR" "$NRFVM_STATE_DIR" "$NRFVM_DIR/cache" || mk_status=$?
  umask "$old_umask"

  if [ "$mk_status" -ne 0 ]; then
    return "$mk_status"
  fi

  chmod 700 "$NRFVM_DIR" "$NRFVM_STATE_DIR" "$NRFVM_DIR/cache" 2>/dev/null || true
}

_nrfvm_set_state() {
  local key="$1"
  local value="$2"
  local file=""
  local tmp=""

  case "$key" in
    [A-Za-z0-9._-]*) ;;
    *)
      _nrfvm_err "bad state key: $key"
      return 1
      ;;
  esac

  _nrfvm_mkdirs || return 1
  file="$NRFVM_STATE_DIR/$key"
  if [ -L "$file" ]; then
    _nrfvm_err "state file is symlink: $file"
    return 1
  fi

  tmp="$(mktemp "$NRFVM_STATE_DIR/.${key}.XXXXXX" 2>/dev/null)"
  if [ -z "$tmp" ]; then
    _nrfvm_err "tmp state file failed: $key"
    return 1
  fi

  if ! printf "%s\n" "$value" > "$tmp"; then
    rm -f "$tmp"
    _nrfvm_err "write state failed: $key"
    return 1
  fi

  chmod 600 "$tmp" 2>/dev/null || true
  if ! mv "$tmp" "$file"; then
    rm -f "$tmp"
    _nrfvm_err "save state failed: $key"
    return 1
  fi
}

_nrfvm_get_state() {
  local key="$1"
  local file=""
  local value=""

  case "$key" in
    [A-Za-z0-9._-]*) ;;
    *) return 1 ;;
  esac

  file="$NRFVM_STATE_DIR/$key"
  if [ -L "$file" ]; then
    _nrfvm_warn "skip symlink state file: $file"
    return 1
  fi

  if [ -f "$file" ]; then
    while IFS= read -r value || [ -n "$value" ]; do
      printf "%s\n" "$value"
    done < "$file"
  fi
}

_nrfvm_is_valid_var_name() {
  case "$1" in
    [A-Za-z_][A-Za-z0-9_]*) return 0 ;;
    *) return 1 ;;
  esac
}

_nrfvm_var_is_set() {
  local var_name="$1"
  _nrfvm_is_valid_var_name "$var_name" || return 1
  eval "[ \"\${$var_name+x}\" = \"x\" ]"
}

_nrfvm_var_get_value() {
  local var_name="$1"
  _nrfvm_is_valid_var_name "$var_name" || return 1
  eval "printf '%s' \"\${$var_name}\""
}

_nrfvm_snapshot_var() {
  local var_name="$1"
  local value=""

  _nrfvm_is_valid_var_name "$var_name" || return 1

  if _nrfvm_var_is_set "$var_name"; then
    value="$(_nrfvm_var_get_value "$var_name")"
    _nrfvm_set_state "env-prev-var-${var_name}-set" "1" || return 1
    _nrfvm_set_state "env-prev-var-${var_name}-value" "$value" || return 1
    return 0
  fi

  _nrfvm_set_state "env-prev-var-${var_name}-set" "0" || return 1
  _nrfvm_set_state "env-prev-var-${var_name}-value" "" || return 1
}

_nrfvm_restore_var() {
  local var_name="$1"
  local was_set=""
  local value=""

  _nrfvm_is_valid_var_name "$var_name" || return 1

  was_set="$(_nrfvm_get_state "env-prev-var-${var_name}-set")"
  case "$was_set" in
    1)
      value="$(_nrfvm_get_state "env-prev-var-${var_name}-value")"
      export "$var_name=$value"
      ;;
    0)
      unset "$var_name"
      ;;
  esac
}

_nrfvm_collect_toolchain_env_vars() {
  local env_script="$1"
  local line=""
  local assign=""
  local var_name=""

  while IFS= read -r line; do
    case "$line" in
      ''|'#'*) continue ;;
      export\ *=*) ;;
      *) continue ;;
    esac

    assign="${line#export }"
    var_name="${assign%%=*}"
    if _nrfvm_is_valid_var_name "$var_name"; then
      printf "%s\n" "$var_name"
    fi
  done <<EOF
$env_script
EOF
}

_nrfvm_snapshot_sdk_env() {
  local env_vars="$1"
  local var_name=""
  local prev_sdk=""

  _nrfvm_set_state "env-prev-vars" "$env_vars" || return 1

  while IFS= read -r var_name; do
    [ -n "$var_name" ] || continue
    _nrfvm_snapshot_var "$var_name" || return 1
  done <<EOF
$env_vars
EOF

  prev_sdk="$(_nrfvm_get_state "current-sdk")"
  _nrfvm_set_state "env-prev-current-sdk" "$prev_sdk" || return 1
  _nrfvm_set_state "env-active" "0"
}

_nrfvm_restore_legacy_sdk_env() {
  local was_set=""
  local value=""

  was_set="$(_nrfvm_get_state "env-prev-path-set")"
  case "$was_set" in
    1)
      value="$(_nrfvm_get_state "env-prev-path-value")"
      export PATH="$value"
      ;;
    0)
      unset PATH
      ;;
  esac

  was_set="$(_nrfvm_get_state "env-prev-zephyr-base-set")"
  case "$was_set" in
    1)
      value="$(_nrfvm_get_state "env-prev-zephyr-base-value")"
      export ZEPHYR_BASE="$value"
      ;;
    0)
      unset ZEPHYR_BASE
      ;;
  esac

  was_set="$(_nrfvm_get_state "env-prev-sdk-version-set")"
  case "$was_set" in
    1)
      value="$(_nrfvm_get_state "env-prev-sdk-version-value")"
      export NRFVM_SDK_VERSION="$value"
      ;;
    0)
      unset NRFVM_SDK_VERSION
      ;;
  esac
}

_nrfvm_restore_sdk_env() {
  local env_vars=""
  local var_name=""

  env_vars="$(_nrfvm_get_state "env-prev-vars")"
  if [ -z "$env_vars" ]; then
    _nrfvm_restore_legacy_sdk_env
    return 0
  fi

  while IFS= read -r var_name; do
    [ -n "$var_name" ] || continue
    _nrfvm_restore_var "$var_name"
  done <<EOF
$env_vars
EOF
}

_nrfvm_apply_config_entry() {
  local key="$1"
  local value="$2"

  case "$key" in
    NRFVM_DEFAULT_TARGET|default_target)
      case "$value" in
        sdk|nrfutil) NRFVM_DEFAULT_TARGET="$value" ;;
        *) _nrfvm_warn "skip bad default_target: $value" ;;
      esac
      ;;
    NRFVM_REMOTE_CACHE_TTL|remote_cache_ttl)
      case "$value" in
        ''|*[!0-9]*) _nrfvm_warn "skip bad remote_cache_ttl: $value" ;;
        *) NRFVM_REMOTE_CACHE_TTL="$value" ;;
      esac
      ;;
    NRFVM_AUTO_INSTALL_PLUGINS|auto_install_plugins)
      case "$value" in
        prompt|always|never) NRFVM_AUTO_INSTALL_PLUGINS="$value" ;;
        *) _nrfvm_warn "skip bad auto_install_plugins: $value" ;;
      esac
      ;;
  esac
}

_nrfvm_load_config() {
  local line=""
  local key=""
  local value=""

  NRFVM_DEFAULT_TARGET="sdk"
  NRFVM_REMOTE_CACHE_TTL="3600"
  NRFVM_AUTO_INSTALL_PLUGINS="prompt"

  if [ -L "$NRFVM_CONFIG_FILE" ]; then
    _nrfvm_warn "skip symlink config: $NRFVM_CONFIG_FILE"
    return 0
  fi

  if [ -f "$NRFVM_CONFIG_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      line="${line%$'\r'}"
      case "$line" in
        ''|'#'*) continue ;;
      esac

      case "$line" in
        *=*) ;;
        *) continue ;;
      esac

      key="${line%%=*}"
      value="${line#*=}"
      key="$(printf "%s" "$key" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
      value="$(printf "%s" "$value" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"

      case "$value" in
        ""|'' ) ;;
        \"*\")
          value="${value#\"}"
          value="${value%\"}"
          ;;
        \'*\')
          value="${value#\'}"
          value="${value%\'}"
          ;;
      esac

      _nrfvm_apply_config_entry "$key" "$value"
    done < "$NRFVM_CONFIG_FILE"
  fi
}

_nrfvm_save_config() {
  local tmp=""

  _nrfvm_mkdirs || return 1

  if [ -L "$NRFVM_CONFIG_FILE" ]; then
    _nrfvm_err "config file is symlink: $NRFVM_CONFIG_FILE"
    return 1
  fi

  tmp="$(mktemp "$NRFVM_DIR/.config.XXXXXX" 2>/dev/null)"
  if [ -z "$tmp" ]; then
    _nrfvm_err "tmp config file failed"
    return 1
  fi

  if ! cat > "$tmp" <<EOF
NRFVM_DEFAULT_TARGET=$NRFVM_DEFAULT_TARGET
NRFVM_REMOTE_CACHE_TTL=$NRFVM_REMOTE_CACHE_TTL
NRFVM_AUTO_INSTALL_PLUGINS=$NRFVM_AUTO_INSTALL_PLUGINS
EOF
  then
    rm -f "$tmp"
    _nrfvm_err "write config failed"
    return 1
  fi

  chmod 600 "$tmp" 2>/dev/null || true
  if ! mv "$tmp" "$NRFVM_CONFIG_FILE"; then
    rm -f "$tmp"
    _nrfvm_err "save config failed"
    return 1
  fi
}

_nrfvm_preflight() {
  if ! _nrfvm_is_supported_shell; then
    _nrfvm_err "shell not supported; use bash/zsh"
    _nrfvm_info "run in bash/zsh shell"
    return 1
  fi

  if ! command -v nrfutil >/dev/null 2>&1; then
    _nrfvm_err "nrfutil not in PATH"
    _nrfvm_info "install nrfutil: https://docs.nordicsemi.com/"
    _nrfvm_info "check: nrfutil --version"
    return 1
  fi

  return 0
}

_nrfvm_requires_sourced() {
  if _nrfvm_is_sourced; then
    return 0
  fi

  _nrfvm_err "run in sourced shell"
  _nrfvm_info "add to rc: source /path/to/nrfvm"
  _nrfvm_info "open new shell, retry"
  return 1
}

_nrfvm_prompt_yes_no() {
  local prompt="$1"
  local answer=""
  printf "%s [y/N]: " "$prompt" >&2
  IFS= read -r answer || true
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

_nrfvm_has_nrfutil_command() {
  local name="$1"
  nrfutil "$name" --help >/dev/null 2>&1
}

_nrfvm_ensure_plugin() {
  local plugin="$1"
  local plugin_spec="$plugin"
  if [ -n "${2:-}" ]; then
    plugin_spec="${plugin}=$2"
  fi

  if _nrfvm_has_nrfutil_command "$plugin"; then
    return 0
  fi

  if ! _nrfvm_prompt_yes_no "plugin '$plugin' missing. install?"; then
    _nrfvm_err "need plugin: $plugin"
    _nrfvm_info "manual install: nrfutil install $plugin_spec"
    return 1
  fi

  if ! nrfutil install "$plugin_spec"; then
    _nrfvm_err "plugin install failed: $plugin_spec"
    return 1
  fi

  if ! _nrfvm_has_nrfutil_command "$plugin"; then
    _nrfvm_err "plugin still missing: $plugin"
    return 1
  fi

  return 0
}

_nrfvm_get_configured_sdk_install_dir() {
  local out=""
  local dir=""

  out="$(nrfutil --json sdk-manager config show 2>/dev/null || true)"
  dir="$(printf "%s\n" "$out" | sed -n 's/.*"install_dir":"\([^"]*\)".*/\1/p')"
  if [ -n "$dir" ]; then
    printf "%s" "$dir"
    return 0
  fi

  if printf "%s\n" "$out" | grep -q '"install_dir":null'; then
    return 1
  fi

  out="$(nrfutil sdk-manager config show 2>/dev/null || true)"
  dir="$(printf "%s\n" "$out" | sed -n 's/^[[:space:]]*install-dir:[[:space:]]*\(.*\)$/\1/p' | head -n 1)"
  if [ -n "$dir" ] && [ "$dir" != "unset" ]; then
    printf "%s" "$dir"
    return 0
  fi

  return 1
}

_nrfvm_prompt_install_dir() {
  local default_dir="$1"
  local chosen=""

  printf "\n" >&2
  printf "%s\n" "set sdk install dir" >&2
  printf "dir [%s]: " "$default_dir" >&2
  IFS= read -r chosen || true

  if [ -z "$chosen" ]; then
    chosen="$default_dir"
  fi

  chosen="${chosen/#\~/$HOME}"
  case "$chosen" in
    /*) ;;
    *) chosen="$PWD/$chosen" ;;
  esac

  printf "%s" "$chosen"
}

_nrfvm_ensure_sdk_install_dir() {
  local configured=""
  local default_dir=""
  local chosen=""

  configured="$(_nrfvm_get_configured_sdk_install_dir || true)"
  if [ -n "$configured" ]; then
    return 0
  fi

  default_dir="$(_nrfvm_default_sdk_install_dir)"

  if ! _nrfvm_sdk_install_dir_is_configurable; then
    _nrfvm_info "sdk dir fixed: $default_dir"
    return 0
  fi

  chosen="$(_nrfvm_prompt_install_dir "$default_dir")"
  if [ -z "$chosen" ]; then
    chosen="$default_dir"
  fi

  if ! mkdir -p "$chosen" 2>/dev/null; then
    _nrfvm_err "mkdir failed: $chosen"
    return 1
  fi

  if ! nrfutil sdk-manager config install-dir set "$chosen" >/dev/null; then
    _nrfvm_err "set sdk dir failed"
    _nrfvm_info "run: nrfutil sdk-manager config install-dir set \"$chosen\""
    return 1
  fi

  _nrfvm_info "sdk dir: $chosen"
  return 0
}

_nrfvm_get_sdk_install_root() {
  local configured=""

  configured="$(_nrfvm_get_configured_sdk_install_dir || true)"
  if [ -n "$configured" ]; then
    printf "%s" "$configured"
    return 0
  fi

  _nrfvm_default_sdk_install_dir
}

_nrfvm_resolve_zephyr_base() {
  local version="$1"
  local install_root="$2"
  local version_no_v="${version#v}"
  local candidate=""

  for candidate in \
    "$install_root/$version/zephyr" \
    "$install_root/$version_no_v/zephyr" \
    "$install_root/$version/nrf/zephyr" \
    "$install_root/$version_no_v/nrf/zephyr" \
    "$install_root/nrf/$version/zephyr" \
    "$install_root/nrf/$version_no_v/zephyr"
  do
    if [ -d "$candidate" ]; then
      printf "%s" "$candidate"
      return 0
    fi
  done

  printf "%s" "$install_root/$version/zephyr"
}

_nrfvm_set_zephyr_base() {
  local version="$1"
  local install_root="${2:-}"
  local zephyr_base=""

  if [ -z "$install_root" ]; then
    install_root="$(_nrfvm_get_sdk_install_root)"
  fi
  zephyr_base="$(_nrfvm_resolve_zephyr_base "$version" "$install_root")"
  export ZEPHYR_BASE="$zephyr_base"
}

_nrfvm_normalize_sdk_version() {
  local version="$1"
  if [ -z "$version" ]; then
    printf "%s" "$version"
    return
  fi

  case "$version" in
    v*) printf "%s" "$version" ;;
    [0-9]*) printf "v%s" "$version" ;;
    *) printf "%s" "$version" ;;
  esac
}

_nrfvm_sdk_has_top_level() {
  local cmd="$1"
  nrfutil sdk-manager "$cmd" --help >/dev/null 2>&1
}

_nrfvm_sdk_has_nested() {
  local cmd="$1"
  nrfutil sdk-manager sdk "$cmd" --help >/dev/null 2>&1
}

_nrfvm_run_sdk_manager() {
  local action="$1"
  shift
  if ! _nrfvm_ensure_plugin "sdk-manager"; then
    return 1
  fi

  if ! _nrfvm_ensure_sdk_install_dir; then
    return 1
  fi

  case "$action" in
    install)
      if _nrfvm_sdk_has_top_level "install"; then
        nrfutil sdk-manager install "$@"
        return $?
      fi
      if _nrfvm_sdk_has_nested "install"; then
        nrfutil sdk-manager sdk install "$@"
        return $?
      fi
      ;;
    list)
      if _nrfvm_sdk_has_top_level "list"; then
        nrfutil sdk-manager list "$@"
        return $?
      fi
      if _nrfvm_sdk_has_nested "search"; then
        nrfutil sdk-manager sdk search "$@"
        return $?
      fi
      ;;
    remote)
      if _nrfvm_sdk_has_top_level "search"; then
        nrfutil sdk-manager search "$@"
        return $?
      fi
      if _nrfvm_sdk_has_nested "search"; then
        nrfutil sdk-manager sdk search "$@"
        return $?
      fi
      ;;
    uninstall)
      if _nrfvm_sdk_has_top_level "uninstall"; then
        nrfutil sdk-manager uninstall "$@"
        return $?
      fi
      if _nrfvm_sdk_has_nested "uninstall"; then
        nrfutil sdk-manager sdk uninstall "$@"
        return $?
      fi
      ;;
    *)
      _nrfvm_err "bad sdk action: $action"
      return 1
      ;;
  esac

  _nrfvm_err "sdk cmd map failed: $action"
  _nrfvm_info "check: nrfutil sdk-manager --help"
  return 1
}

_nrfvm_sdk_is_installed() {
  local version="$1"
  local version_no_v="${version#v}"
  local out=""
  local compact=""
  local line=""
  local rest=""
  local matched=0

  out="$(nrfutil sdk-manager list --styling never "$version" 2>/dev/null || nrfutil sdk-manager list "$version" 2>/dev/null || true)"
  while IFS= read -r line; do
    matched=0
    case "$line" in
      *"$version"*)
        rest="${line#*"$version"}"
        matched=1
        ;;
      *"$version_no_v"*)
        rest="${line#*"$version_no_v"}"
        matched=1
        ;;
      *)
        continue
        ;;
    esac

    if [ "$matched" -eq 0 ]; then
      continue
    fi

    rest="$(printf "%s" "$rest" | sed 's/^[[:space:]]*//')"
    case "$rest" in
      [Ii]nstalled*) return 0 ;;
      [Nn]ot[[:space:]]*[Ii]nstalled*) continue ;;
      [Mm]issing*) continue ;;
    esac
  done <<EOF
$out
EOF

  out="$(nrfutil --json sdk-manager list "$version" 2>/dev/null || true)"
  compact="$(printf "%s" "$out" | tr -d '[:space:]')"

  case "$compact" in
    *"\"sdkVersion\":\"$version\""*"\"sdkStatus\":\"installed\""*) return 0 ;;
    *"\"sdkVersion\":\"$version\""*"\"sdkStatus\":\"Installed\""*) return 0 ;;
    *"\"sdk_version\":\"$version\""*"\"sdk_status\":\"installed\""*) return 0 ;;
    *"\"sdk_version\":\"$version\""*"\"sdk_status\":\"Installed\""*) return 0 ;;
    *"\"version\":\"$version\""*"\"status\":\"installed\""*) return 0 ;;
    *"\"version\":\"$version\""*"\"status\":\"Installed\""*) return 0 ;;
  esac

  case "$compact" in
    *"\"sdkVersion\":\"$version_no_v\""*"\"sdkStatus\":\"installed\""*) return 0 ;;
    *"\"sdkVersion\":\"$version_no_v\""*"\"sdkStatus\":\"Installed\""*) return 0 ;;
    *"\"sdk_version\":\"$version_no_v\""*"\"sdk_status\":\"installed\""*) return 0 ;;
    *"\"sdk_version\":\"$version_no_v\""*"\"sdk_status\":\"Installed\""*) return 0 ;;
    *"\"version\":\"$version_no_v\""*"\"status\":\"installed\""*) return 0 ;;
    *"\"version\":\"$version_no_v\""*"\"status\":\"Installed\""*) return 0 ;;
  esac

  return 1
}

_nrfvm_validate_toolchain_env_script() {
  local env_script="$1"
  local line=""
  local assign=""
  local var_name=""
  local var_value=""

  while IFS= read -r line; do
    case "$line" in
      ''|'#'*) continue ;;
      export\ *=*) ;;
      *)
        _nrfvm_err "bad toolchain env line"
        return 1
        ;;
    esac

    assign="${line#export }"
    var_name="${assign%%=*}"
    var_value="${assign#*=}"

    case "$var_name" in
      [A-Za-z_][A-Za-z0-9_]*) ;;
      *)
        _nrfvm_err "bad toolchain env var: $var_name"
        return 1
        ;;
    esac

    case "$var_value" in
      *';'*|*'`'*|*'$('*|*'|'*|*'&'*|*'<'*|*'>'*)
        _nrfvm_err "unsafe toolchain env var: $var_name"
        return 1
        ;;
    esac
  done <<EOF
$env_script
EOF

  return 0
}

_nrfvm_activate_toolchain_env() {
  local version="$1"
  local env_script="${2:-}"

  if [ -z "$env_script" ]; then
    if ! env_script="$(nrfutil sdk-manager toolchain env --ncs-version "$version" --as-script sh 2>/dev/null)"; then
      _nrfvm_err "toolchain env resolve failed: $version"
      _nrfvm_info "check: nrfutil sdk-manager toolchain list"
      return 1
    fi
  fi

  if [ -z "$env_script" ]; then
    _nrfvm_err "empty toolchain env: $version"
    return 1
  fi

  if ! _nrfvm_validate_toolchain_env_script "$env_script"; then
    _nrfvm_err "unsafe toolchain env blocked: $version"
    return 1
  fi

  if ! eval "$env_script"; then
    _nrfvm_err "toolchain env apply failed: $version"
    return 1
  fi

  if ! command -v west >/dev/null 2>&1; then
    _nrfvm_warn "west not in PATH after env"
    _nrfvm_info "inspect: nrfutil sdk-manager toolchain env --ncs-version $version --as-script sh"
  fi

  return 0
}

_nrfvm_use_sdk() {
  local version="$1"
  local sdk_install_root=""
  local env_script=""
  local env_vars=""
  if [ -z "$version" ]; then
    _nrfvm_err "usage: nrfvm use <version>"
    return 1
  fi
  version="$(_nrfvm_normalize_sdk_version "$version")"
  _nrfvm_requires_sourced || return 1

  _nrfvm_ensure_plugin "sdk-manager" || return 1
  _nrfvm_ensure_sdk_install_dir || return 1

  if ! _nrfvm_sdk_is_installed "$version"; then
    if ! _nrfvm_prompt_yes_no "sdk $version missing. install?"; then
      _nrfvm_err "sdk install canceled: $version"
      return 1
    fi
    _nrfvm_info "install sdk: $version"
    _nrfvm_run_sdk_manager install "$version" || return 1
  fi

  if ! env_script="$(nrfutil sdk-manager toolchain env --ncs-version "$version" --as-script sh 2>/dev/null)"; then
    _nrfvm_err "toolchain env resolve failed: $version"
    _nrfvm_info "check: nrfutil sdk-manager toolchain list"
    return 1
  fi

  if [ -z "$env_script" ]; then
    _nrfvm_err "empty toolchain env: $version"
    return 1
  fi

  if ! _nrfvm_validate_toolchain_env_script "$env_script"; then
    _nrfvm_err "unsafe toolchain env blocked: $version"
    return 1
  fi

  env_vars="$(_nrfvm_collect_toolchain_env_vars "$env_script")"
  env_vars="${env_vars}PATH
ZEPHYR_BASE
NRFVM_SDK_VERSION"

  _nrfvm_snapshot_sdk_env "$env_vars" || return 1
  sdk_install_root="$(_nrfvm_get_sdk_install_root)"
  if ! _nrfvm_activate_toolchain_env "$version" "$env_script"; then
    _nrfvm_restore_sdk_env
    return 1
  fi
  _nrfvm_set_zephyr_base "$version" "$sdk_install_root"

  export NRFVM_SDK_VERSION="$version"
  _nrfvm_set_state "current-sdk" "$version"
  _nrfvm_set_state "env-active" "1"
  _nrfvm_info "using sdk: $version"
}

_nrfvm_deactivate_sdk() {
  local active=""
  local prev_sdk=""

  _nrfvm_requires_sourced || return 1

  active="$(_nrfvm_get_state "env-active")"
  if [ "$active" != "1" ]; then
    _nrfvm_info "no active sdk env"
    return 0
  fi

  prev_sdk="$(_nrfvm_get_state "env-prev-current-sdk")"
  _nrfvm_set_state "current-sdk" "$prev_sdk"
  _nrfvm_set_state "env-active" "0"
  _nrfvm_restore_sdk_env
  _nrfvm_info "sdk env off"
}

_nrfvm_install_sdk() {
  local version="$1"
  if [ -z "$version" ]; then
    _nrfvm_err "usage: nrfvm install <version>"
    return 1
  fi
  version="$(_nrfvm_normalize_sdk_version "$version")"
  _nrfvm_run_sdk_manager install "$version"
}

_nrfvm_list_sdk() {
  _nrfvm_run_sdk_manager list
}

_nrfvm_remote_sdk() {
  if _nrfvm_ensure_plugin "sdk-manager"; then
    if _nrfvm_run_sdk_manager remote; then
      return 0
    fi
  fi
  nrfutil search sdk
}

_nrfvm_install_nrfutil_target() {
  local spec="$1"
  if [ -z "$spec" ]; then
    _nrfvm_err "usage: nrfvm -n install <plugin[=version]>"
    return 1
  fi
  nrfutil install "$spec"
}

_nrfvm_use_nrfutil_target() {
  local spec="$1"
  if [ -z "$spec" ]; then
    _nrfvm_err "usage: nrfvm -n use <plugin[=version]>"
    return 1
  fi
  _nrfvm_requires_sourced || return 1
  _nrfvm_set_state "current-nrfutil" "$spec"
  export NRFVM_NRFUTIL_SELECTION="$spec"
  _nrfvm_info "nrfutil target: $spec"
}

_nrfvm_list_nrfutil_target() {
  nrfutil list
}

_nrfvm_remote_nrfutil_target() {
  local q="${1:-}"
  nrfutil search "$q"
}

_nrfvm_current() {
  local target="$1"
  case "$target" in
    sdk)
      local sdk_cur
      sdk_cur="$(_nrfvm_get_state "current-sdk")"
      if [ -n "$sdk_cur" ]; then
        _nrfvm_info "sdk: $sdk_cur"
      else
        _nrfvm_info "sdk: (none)"
      fi
      ;;
    nrfutil)
      local n_cur
      n_cur="$(_nrfvm_get_state "current-nrfutil")"
      if [ -n "$n_cur" ]; then
        _nrfvm_info "nrfutil: $n_cur"
      else
        _nrfvm_info "nrfutil: (none)"
      fi
      ;;
    *)
      _nrfvm_current sdk
      _nrfvm_current nrfutil
      ;;
  esac
}

_nrfvm_status() {
  local sdk_install_dir=""
  local sdk_default_dir=""

  sdk_install_dir="$(_nrfvm_get_configured_sdk_install_dir || true)"
  sdk_default_dir="$(_nrfvm_default_sdk_install_dir)"

  _nrfvm_info "nrfvm: $NRFVM_VERSION"
  _nrfvm_info "nrfutil: $(command -v nrfutil)"
  _nrfvm_info "nrfutil ver: $(nrfutil --version 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
  if [ -n "$sdk_install_dir" ]; then
    _nrfvm_info "sdk dir: $sdk_install_dir"
  else
    _nrfvm_info "sdk dir: unset (default: $sdk_default_dir)"
  fi
  _nrfvm_info "cfg dir: $NRFVM_DIR"
  _nrfvm_current
}

_nrfvm_config() {
  local action="${1:-list}"
  local key="${2:-}"
  local value="${3:-}"

  _nrfvm_load_config

  case "$action" in
    list|show)
      _nrfvm_info "NRFVM_DEFAULT_TARGET=$NRFVM_DEFAULT_TARGET"
      _nrfvm_info "NRFVM_REMOTE_CACHE_TTL=$NRFVM_REMOTE_CACHE_TTL"
      _nrfvm_info "NRFVM_AUTO_INSTALL_PLUGINS=$NRFVM_AUTO_INSTALL_PLUGINS"
      ;;
    set)
      case "$key" in
        default_target)
          case "$value" in
            sdk|nrfutil) ;;
            *)
              _nrfvm_err "bad default_target: $value"
              _nrfvm_info "allowed: sdk|nrfutil"
              return 1
              ;;
          esac
          NRFVM_DEFAULT_TARGET="$value"
          ;;
        remote_cache_ttl)
          case "$value" in
            ''|*[!0-9]*)
              _nrfvm_err "bad remote_cache_ttl: $value"
              _nrfvm_info "allowed: integer seconds"
              return 1
              ;;
          esac
          NRFVM_REMOTE_CACHE_TTL="$value"
          ;;
        auto_install_plugins)
          case "$value" in
            prompt|always|never) ;;
            *)
              _nrfvm_err "bad auto_install_plugins: $value"
              _nrfvm_info "allowed: prompt|always|never"
              return 1
              ;;
          esac
          NRFVM_AUTO_INSTALL_PLUGINS="$value"
          ;;
        *)
          _nrfvm_err "bad config key: $key"
          return 1
          ;;
      esac
      _nrfvm_save_config || return 1
      _nrfvm_info "set $key"
      ;;
    unset)
      case "$key" in
        default_target) NRFVM_DEFAULT_TARGET="sdk" ;;
        remote_cache_ttl) NRFVM_REMOTE_CACHE_TTL="3600" ;;
        auto_install_plugins) NRFVM_AUTO_INSTALL_PLUGINS="prompt" ;;
        *)
          _nrfvm_err "bad config key: $key"
          return 1
          ;;
      esac
      _nrfvm_save_config || return 1
      _nrfvm_info "unset $key"
      ;;
    *)
      _nrfvm_err "usage: nrfvm config [list|show|set|unset]"
      return 1
      ;;
  esac
}

_nrfvm_help() {
  cat <<'EOF'
nrfvm - nRF sdk switch helper

Usage:
  nrfvm [-s|-n] <command> [args]
  nrfvm <sdk-version>

Targets:
  -s            sdk target (default)
  -n            nrfutil target
  sdk           sdk target alias
  nrfutil       nrfutil target alias

Commands:
  i, install    install version
  u, use        use version
  d, deactive/deactivate  restore env
  ls, list      list installed
  r, remote     list remote
  c, current    show current
  st, status    show status
  cfg, config   show/set config
  help          show help

Examples:
  nrfvm 2.9.0
  nrfvm -s install 2.9.0
  nrfvm -n install sdk-manager=1.11.0
  nrfvm -n list
EOF
}

_nrfvm_handle_sdk() {
  local cmd="$1"
  shift
  case "$cmd" in
    i|install) _nrfvm_install_sdk "$@" ;;
    u|use) _nrfvm_use_sdk "$@" ;;
    d|deactive|deactivate) _nrfvm_deactivate_sdk ;;
    ls|list) _nrfvm_list_sdk "$@" ;;
    r|remote) _nrfvm_remote_sdk "$@" ;;
    c|current) _nrfvm_current sdk ;;
    st|status) _nrfvm_status ;;
    cfg|config) _nrfvm_config "$@" ;;
    help|--help|-h|"") _nrfvm_help ;;
    *)
      _nrfvm_err "bad sdk cmd: $cmd"
      _nrfvm_help
      return 1
      ;;
  esac
}

_nrfvm_handle_nrfutil() {
  local cmd="$1"
  shift
  case "$cmd" in
    i|install) _nrfvm_install_nrfutil_target "$@" ;;
    u|use) _nrfvm_use_nrfutil_target "$@" ;;
    d|deactive|deactivate) _nrfvm_deactivate_sdk ;;
    ls|list) _nrfvm_list_nrfutil_target "$@" ;;
    r|remote) _nrfvm_remote_nrfutil_target "$@" ;;
    c|current) _nrfvm_current nrfutil ;;
    st|status) _nrfvm_status ;;
    cfg|config) _nrfvm_config "$@" ;;
    help|--help|-h|"") _nrfvm_help ;;
    *)
      _nrfvm_err "bad nrfutil cmd: $cmd"
      _nrfvm_help
      return 1
      ;;
  esac
}

_nrfvm_parse_shorthand() {
  local token="$1"
  if printf "%s" "$token" | grep -Eq '^sdk@[A-Za-z0-9._-]+$'; then
    printf "sdk:%s" "${token#sdk@}"
    return 0
  fi
  if printf "%s" "$token" | grep -Eq '^nrfutil@[A-Za-z0-9._-]+(=[A-Za-z0-9._-]+)?$'; then
    printf "nrfutil:%s" "${token#nrfutil@}"
    return 0
  fi
  if printf "%s" "$token" | grep -Eq '^v?[0-9]+(\.[0-9]+){1,3}([._-][A-Za-z0-9]+)?$'; then
    printf "sdk:%s" "$token"
    return 0
  fi
  return 1
}

nrfvm() {
  _nrfvm_preflight || return 1
  _nrfvm_load_config

  local target="$NRFVM_DEFAULT_TARGET"
  local first="${1:-}"

  case "$first" in
    -s) target="sdk"; shift ;;
    -n) target="nrfutil"; shift ;;
    sdk) target="sdk"; shift ;;
    nrfutil) target="nrfutil"; shift ;;
  esac

  local cmd="${1:-}"
  shift 2>/dev/null || true

  local parsed=""
  if [ -n "$cmd" ] && parsed="$(_nrfvm_parse_shorthand "$cmd")"; then
    local parsed_target="${parsed%%:*}"
    local parsed_value="${parsed#*:}"
    if [ "$parsed_target" = "sdk" ]; then
      _nrfvm_handle_sdk use "$parsed_value"
      return $?
    fi
    _nrfvm_handle_nrfutil use "$parsed_value"
    return $?
  fi

  case "$target" in
    sdk) _nrfvm_handle_sdk "$cmd" "$@" ;;
    nrfutil) _nrfvm_handle_nrfutil "$cmd" "$@" ;;
    *)
      _nrfvm_err "bad target: $target"
      return 1
      ;;
  esac
}

_nrfvm_register_completion() {
  if command -v complete >/dev/null 2>&1; then
    complete -F _nrfvm_bash_completion nrfvm 2>/dev/null || true
    return
  fi
  if _nrfvm_is_zsh; then
    autoload -Uz bashcompinit 2>/dev/null || return
    bashcompinit 2>/dev/null || return
    complete -F _nrfvm_bash_completion nrfvm 2>/dev/null || true
  fi
}

_nrfvm_bash_completion() {
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  local commands="install use deactive deactivate list remote current status config help i u d ls r c st cfg"
  local targets="-s -n sdk nrfutil"
  local config_actions="list show set unset"
  local config_keys="default_target remote_cache_ttl auto_install_plugins"

  if [ "$COMP_CWORD" -eq 1 ]; then
    COMPREPLY=( $(compgen -W "$targets $commands" -- "$cur") )
    return
  fi

  if [ "$prev" = "config" ] || [ "$prev" = "cfg" ]; then
    COMPREPLY=( $(compgen -W "$config_actions" -- "$cur") )
    return
  fi

  if [ "$prev" = "set" ] || [ "$prev" = "unset" ]; then
    COMPREPLY=( $(compgen -W "$config_keys" -- "$cur") )
    return
  fi

  COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
}

_nrfvm_register_completion

if [ "${BASH_SOURCE[0]:-}" = "$0" ]; then
  nrfvm "$@"
fi
